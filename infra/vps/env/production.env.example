# Copy to `/etc/ping-watch/production.env` on the VPS.

# Runtime mode
# Required in hosted production so backend write routes are protected.
AUTH_REQUIRED=true
# Required in hosted production; keep disabled so the dev bootstrap login route is not exposed.
AUTH_DEV_LOGIN_ENABLED=false
# Optional; token lifetime in seconds for authenticated sessions.
AUTH_TOKEN_TTL_SECONDS=86400
# Optional; baseline protection if dev login is ever re-enabled temporarily.
AUTH_DEV_LOGIN_RATE_LIMIT_MAX_REQUESTS=10
# Optional; sliding-window size for the dev-login rate limiter.
AUTH_DEV_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
# Optional; worker log verbosity in system logs.
WORKER_LOG_LEVEL=INFO
# Required when `AUTH_REQUIRED=true`; lets the worker post summaries/results back to the backend.
WORKER_API_TOKEN=replace-with-production-worker-token
# Required; production backend bind port used by the nginx config.
PORT=8000

# Azure managed PostgreSQL
# Required; SQLAlchemy database URL for production Azure Postgres.
DATABASE_URL=postgresql+psycopg://prod_user:prod_password@prod-postgres-host:5432/pingwatch

# Azure managed Redis
# Required; queue connection string. For the cheapest MVP path, run Redis on the VPS and keep this as localhost.
REDIS_URL=redis://127.0.0.1:6379/0

# Azure Blob Storage
# Required; Blob Storage endpoint used for SAS URL generation and worker downloads.
AZURITE_BLOB_ENDPOINT=https://prodstorageaccount.blob.core.windows.net
# Required; Blob Storage account name.
AZURITE_ACCOUNT_NAME=prodstorageaccount
# Required; Blob Storage account key used to sign SAS uploads.
AZURITE_ACCOUNT_KEY=replace-with-production-storage-key
# Required; blob container name for production clip uploads.
AZURITE_CLIPS_CONTAINER=clips
# Required in hosted production; keep `false` after the container has been created.
AZURITE_AUTO_CREATE_CONTAINER=false
# Optional; SAS upload URL lifetime in seconds.
AZURITE_SAS_EXPIRY_SECONDS=900

# Frontend/API routing
# The frontend deploy workflow sets its own build-time API URL.
# Keep backend CORS aligned with the public production path-hosted frontend.
# Optional unless you need to expand allowed browser origins beyond the main production origin.
BACKEND_CORS_ORIGINS=https://your-domain.example

# Inference providers
# Optional; required only when using NVIDIA-hosted inference.
NVIDIA_API_KEY=
# Optional; required only when using Hugging Face-hosted inference.
HF_TOKEN=
# Optional; number of frames sampled per clip for inference.
INFERENCE_NUM_FRAMES=3
# Optional; outbound inference request timeout in seconds.
INFERENCE_TIMEOUT_SECONDS=120
# Optional; extra retries when NVIDIA inference times out.
NVIDIA_INFERENCE_TIMEOUT_RETRIES=1

# Telegram and outbound notifications
# Optional; required only when Telegram notifications/linking are enabled in production.
TELEGRAM_BOT_TOKEN=
# Optional; required only when Telegram notifications/linking are enabled in production.
TELEGRAM_BOT_ONBOARDING_URL=https://t.me/your_production_bot
# Optional override for Telegram API base URL.
TELEGRAM_API_BASE_URL=
# Optional; one-time token lifetime for Telegram linking.
TELEGRAM_LINK_TOKEN_TTL_SECONDS=600
# Optional but strongly recommended when Telegram webhook is enabled; verifies inbound Telegram webhook calls.
TELEGRAM_WEBHOOK_SECRET=replace-with-production-telegram-webhook-secret
# Optional; `true` sends clip video to Telegram when available, `false` sends text-only alerts.
TELEGRAM_SEND_VIDEO=true
# Optional; set this to send outbound alert payloads to another system in addition to Telegram.
NOTIFY_WEBHOOK_URL=
# Optional; shared secret header for the outbound webhook target above.
NOTIFY_WEBHOOK_SECRET=
# Optional; timeout in seconds for outbound notification requests.
NOTIFICATION_TIMEOUT_SECONDS=10
