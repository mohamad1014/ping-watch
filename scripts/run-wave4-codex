#!/usr/bin/env bash
set -euo pipefail

scripts_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd "$scripts_dir/.." && pwd)
workspace_root=$(cd "$repo_root/.." && pwd)

require_command() {
  local name="$1"
  if ! command -v "$name" >/dev/null 2>&1; then
    echo "missing required command: $name" >&2
    exit 1
  fi
}

require_worktree() {
  local path="$1"
  local branch="$2"

  if [[ ! -d "$path/.git" && ! -f "$path/.git" ]]; then
    echo "missing worktree: $path" >&2
    echo "run ./scripts/create-wave4-worktrees first" >&2
    exit 1
  fi

  local current_branch
  current_branch=$(git -C "$path" rev-parse --abbrev-ref HEAD)
  if [[ "$current_branch" != "$branch" ]]; then
    echo "expected branch '$branch' in $path, found '$current_branch'" >&2
    exit 1
  fi
}

detect_terminal() {
  if command -v x-terminal-emulator >/dev/null 2>&1; then
    echo "x-terminal-emulator"
    return
  fi
  if command -v gnome-terminal >/dev/null 2>&1; then
    echo "gnome-terminal"
    return
  fi
  if command -v konsole >/dev/null 2>&1; then
    echo "konsole"
    return
  fi
  if command -v xfce4-terminal >/dev/null 2>&1; then
    echo "xfce4-terminal"
    return
  fi
  if command -v kitty >/dev/null 2>&1; then
    echo "kitty"
    return
  fi
  echo ""
}

launch_terminal() {
  local terminal="$1"
  local title="$2"
  local worktree="$3"
  local prompt="$4"
  local escaped_worktree
  local escaped_prompt
  local command

  escaped_worktree=$(printf '%q' "$worktree")
  escaped_prompt=$(printf '%q' "$prompt")
  command="cd ${escaped_worktree} && codex --no-alt-screen --ask-for-approval never --sandbox danger-full-access ${escaped_prompt}; printf '\\nSession ended for ${title}. Press Enter to close...'; read -r _"

  case "$terminal" in
    x-terminal-emulator)
      x-terminal-emulator -T "$title" -e bash -lc "$command" &
      ;;
    gnome-terminal)
      gnome-terminal --title="$title" -- bash -lc "$command" &
      ;;
    konsole)
      konsole --new-tab -p tabtitle="$title" -e bash -lc "$command" &
      ;;
    xfce4-terminal)
      xfce4-terminal --title="$title" --hold -e "bash -lc $(
        printf '%q' "$command"
      )" &
      ;;
    kitty)
      kitty --title "$title" bash -lc "$command" &
      ;;
    *)
      echo "unsupported terminal: $terminal" >&2
      exit 1
      ;;
  esac
}

require_command git
if ! command -v codex >/dev/null 2>&1; then
  echo "missing required command: codex" >&2
  exit 1
fi

terminal=$(detect_terminal)
if [[ -z "$terminal" ]]; then
  echo "no supported terminal emulator found" >&2
  echo "supported: x-terminal-emulator, gnome-terminal, konsole, xfce4-terminal, kitty" >&2
  exit 1
fi

worktree_pw05="$workspace_root/ping-watch-pw05"
worktree_pw09="$workspace_root/ping-watch-pw09"

prompt_pw05=$(cat <<'EOF'
Work only on PW-05 in this branch.
Task: Implement the invite and share flow so owners can grant and revoke recipient access safely.
Base your work on the merged recipient-management API and frontend controls from Waves 2 and 3.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If the Waves 2 and 3 contracts are not stable on main, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

prompt_pw09=$(cat <<'EOF'
Work only on PW-09 in this branch.
Task: Add notification attempt tracking and retries with provider, recipient, status, failure reason, and retry metadata.
Base your work on the merged fanout path from Wave 3 and the reliability work from Wave 2.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If the dependent reliability or fanout contracts are not stable on main, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

require_worktree "$worktree_pw05" "feature/pw-05-invite-share-flow"
require_worktree "$worktree_pw09" "feature/pw-09-notification-attempt-tracking-retries"

launch_terminal \
  "$terminal" \
  "PW-05" \
  "$worktree_pw05" \
  "$prompt_pw05"

launch_terminal \
  "$terminal" \
  "PW-09" \
  "$worktree_pw09" \
  "$prompt_pw09"

echo "launched one terminal per worktree for Wave 4"
