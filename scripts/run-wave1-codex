#!/usr/bin/env bash
set -euo pipefail

scripts_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd "$scripts_dir/.." && pwd)
workspace_root=$(cd "$repo_root/.." && pwd)

require_command() {
  local name="$1"
  if ! command -v "$name" >/dev/null 2>&1; then
    echo "missing required command: $name" >&2
    exit 1
  fi
}

require_worktree() {
  local path="$1"
  local branch="$2"

  if [[ ! -d "$path/.git" && ! -f "$path/.git" ]]; then
    echo "missing worktree: $path" >&2
    echo "run ./scripts/create-wave1-worktrees first" >&2
    exit 1
  fi

  local current_branch
  current_branch=$(git -C "$path" rev-parse --abbrev-ref HEAD)
  if [[ "$current_branch" != "$branch" ]]; then
    echo "expected branch '$branch' in $path, found '$current_branch'" >&2
    exit 1
  fi
}

detect_terminal() {
  if command -v x-terminal-emulator >/dev/null 2>&1; then
    echo "x-terminal-emulator"
    return
  fi
  if command -v gnome-terminal >/dev/null 2>&1; then
    echo "gnome-terminal"
    return
  fi
  if command -v konsole >/dev/null 2>&1; then
    echo "konsole"
    return
  fi
  if command -v xfce4-terminal >/dev/null 2>&1; then
    echo "xfce4-terminal"
    return
  fi
  if command -v kitty >/dev/null 2>&1; then
    echo "kitty"
    return
  fi
  echo ""
}

launch_terminal() {
  local terminal="$1"
  local title="$2"
  local worktree="$3"
  local prompt="$4"
  local escaped_worktree
  local escaped_prompt
  local command

  escaped_worktree=$(printf '%q' "$worktree")
  escaped_prompt=$(printf '%q' "$prompt")
  command="cd ${escaped_worktree} && codex --no-alt-screen --ask-for-approval never --sandbox danger-full-access ${escaped_prompt}; printf '\\nSession ended for ${title}. Press Enter to close...'; read -r _"

  case "$terminal" in
    x-terminal-emulator)
      x-terminal-emulator -T "$title" -e bash -lc "$command" &
      ;;
    gnome-terminal)
      gnome-terminal --title="$title" -- bash -lc "$command" &
      ;;
    konsole)
      konsole --new-tab -p tabtitle="$title" -e bash -lc "$command" &
      ;;
    xfce4-terminal)
      xfce4-terminal --title="$title" --hold -e "bash -lc $(
        printf '%q' "$command"
      )" &
      ;;
    kitty)
      kitty --title "$title" bash -lc "$command" &
      ;;
    *)
      echo "unsupported terminal: $terminal" >&2
      exit 1
      ;;
  esac
}

require_command git
if ! command -v codex >/dev/null 2>&1; then
  echo "missing required command: codex" >&2
  exit 1
fi

terminal=$(detect_terminal)
if [[ -z "$terminal" ]]; then
  echo "no supported terminal emulator found" >&2
  echo "supported: x-terminal-emulator, gnome-terminal, konsole, xfce4-terminal, kitty" >&2
  exit 1
fi

worktree_pw01="$workspace_root/ping-watch-pw01"
worktree_pw06="$workspace_root/ping-watch-pw06"
worktree_pw10="$workspace_root/ping-watch-pw10"
worktree_pw11="$workspace_root/ping-watch-pw11"
worktree_pw12="$workspace_root/ping-watch-pw12"
worktree_pw13="$workspace_root/ping-watch-pw13"

prompt_pw01=$(cat <<'EOF'
Work only on PW-01 in this branch.
Task: Implement device recipient subscriptions for multi-recipient device alerts.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If you need a contract from another ticket, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

prompt_pw06=$(cat <<'EOF'
Work only on PW-06 in this branch.
Task: Expand event lifecycle states to queued, processing, done, failed, and canceled.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If you need a contract from another ticket, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

prompt_pw10=$(cat <<'EOF'
Work only on PW-10 in this branch.
Task: Make worker logging structured and expose queue or job identifiers consistently.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If you need a contract from another ticket, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

prompt_pw11=$(cat <<'EOF'
Work only on PW-11 in this branch.
Task: Write runbooks and dashboard baseline documentation for queue stalls and notification failures.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If you need a contract from another ticket, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

prompt_pw12=$(cat <<'EOF'
Work only on PW-12 in this branch.
Task: Automate CI or CD and rollback validation with the repo scripts and infra layout.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If you need a contract from another ticket, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

prompt_pw13=$(cat <<'EOF'
Work only on PW-13 in this branch.
Task: Add the security baseline for rate limiting, secret guidance, and CI security checks.
Follow PLAN.md and docs/codex-parallel-workflow.md.
Do test-first.
Do not change unrelated files.
Run targeted tests first, then report exact results.
If you need a contract from another ticket, stop and report the dependency instead of inventing one.
Before finalizing, run the relevant repo verification commands.
EOF
)

require_worktree "$worktree_pw01" "feature/pw-01-device-recipient-subscriptions"
require_worktree "$worktree_pw06" "feature/pw-06-event-lifecycle-expansion"
require_worktree "$worktree_pw10" "ops/pw-10-worker-structured-logs"
require_worktree "$worktree_pw11" "docs/pw-11-runbooks-dashboard-baseline"
require_worktree "$worktree_pw12" "ops/pw-12-cicd-rollback-automation"
require_worktree "$worktree_pw13" "ops/pw-13-security-baseline"

launch_terminal \
  "$terminal" \
  "PW-01" \
  "$worktree_pw01" \
  "$prompt_pw01"

launch_terminal \
  "$terminal" \
  "PW-06" \
  "$worktree_pw06" \
  "$prompt_pw06"

launch_terminal \
  "$terminal" \
  "PW-10" \
  "$worktree_pw10" \
  "$prompt_pw10"

launch_terminal \
  "$terminal" \
  "PW-11" \
  "$worktree_pw11" \
  "$prompt_pw11"

launch_terminal \
  "$terminal" \
  "PW-12" \
  "$worktree_pw12" \
  "$prompt_pw12"

launch_terminal \
  "$terminal" \
  "PW-13" \
  "$worktree_pw13" \
  "$prompt_pw13"

echo "launched one terminal per worktree for Wave 1"
