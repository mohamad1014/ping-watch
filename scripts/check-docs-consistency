#!/usr/bin/env bash
set -euo pipefail

scripts_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd "$scripts_dir/.." && pwd)

status=0

require_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo "missing file: $path"
    status=1
  fi
}

require_executable_script() {
  local name="$1"
  local path="$repo_root/scripts/$name"
  if [[ ! -x "$path" ]]; then
    echo "missing executable script: scripts/$name"
    status=1
  fi
}

require_text() {
  local file="$1"
  local pattern="$2"
  local message="$3"
  if ! grep -Eq "$pattern" "$file"; then
    echo "$message"
    status=1
  fi
}

# Key docs must exist
require_file "$repo_root/README.md"
require_file "$repo_root/AGENTS.md"
require_file "$repo_root/docs/queue-stall-runbook.md"
require_file "$repo_root/docs/notification-failure-runbook.md"
require_file "$repo_root/docs/observability-dashboard-baseline.md"

# Key scripts must exist
for name in dev-up dev test-unit test-integration test-e2e test-all logs; do
  require_executable_script "$name"
done

# AGENTS/README should mention the primary scripts
for name in dev-up dev test-unit test-integration test-e2e test-all logs; do
  require_text "$repo_root/AGENTS.md" "\\./scripts/$name" "AGENTS.md missing ./scripts/$name"
  require_text "$repo_root/README.md" "\\./scripts/$name" "README.md missing ./scripts/$name"
done

# README should link the current operations docs
require_text "$repo_root/README.md" "docs/queue-stall-runbook.md" "README.md missing docs/queue-stall-runbook.md"
require_text "$repo_root/README.md" "docs/notification-failure-runbook.md" "README.md missing docs/notification-failure-runbook.md"
require_text "$repo_root/README.md" "docs/observability-dashboard-baseline.md" "README.md missing docs/observability-dashboard-baseline.md"

# Keep docs aligned to current test-unit behavior
require_text "$repo_root/scripts/test-unit" "worker" "scripts/test-unit no longer runs worker tests"
require_text "$repo_root/AGENTS.md" "frontend \+ backend \+ worker" "AGENTS.md should describe test-unit as frontend + backend + worker"
require_text "$repo_root/README.md" "frontend \+ backend \+ worker" "README.md should describe test-unit as frontend + backend + worker"

# Guard against stale auth status wording
if grep -q "Auth/credits are still pending" "$repo_root/README.md"; then
  echo "README.md contains stale auth status text"
  status=1
fi

if [[ "$status" -ne 0 ]]; then
  echo "docs consistency check failed"
  exit 1
fi

echo "docs consistency check passed"
