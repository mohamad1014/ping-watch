# Local development defaults
# Required for backend database access in local dev.
DATABASE_URL=postgresql+psycopg://pingwatch:pingwatch@localhost:5432/pingwatch
# Optional helper URL for scripts/tools that expect the non-SQLAlchemy Postgres scheme.
POSTGRES_URL=postgresql://pingwatch:pingwatch@localhost:5432/pingwatch
# Required for Redis-backed local queue processing.
REDIS_URL=redis://localhost:6379/0
# Required for local blob uploads; points at the Azurite emulator.
AZURITE_BLOB_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1
# Required for Azurite access in local dev.
AZURITE_ACCOUNT_NAME=devstoreaccount1
# Required for Azurite access in local dev.
AZURITE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
# Required for clip upload/initiate and worker download flows.
AZURITE_CLIPS_CONTAINER=clips
# Optional convenience for local dev; keep `true` locally and `false` in hosted environments.
AZURITE_AUTO_CREATE_CONTAINER=true
# Optional; SAS upload URL lifetime in seconds.
AZURITE_SAS_EXPIRY_SECONDS=900
# Optional; set `true` when backend write routes should require bearer auth.
AUTH_REQUIRED=false
# Development-only auth bootstrap. Disable this outside local/dev and keep the rate limit enabled anywhere it stays on.
AUTH_DEV_LOGIN_ENABLED=true
# Optional; token lifetime in seconds for dev-login sessions.
AUTH_TOKEN_TTL_SECONDS=86400
# Optional; baseline protection for the dev-login route.
AUTH_DEV_LOGIN_RATE_LIMIT_MAX_REQUESTS=10
# Optional; sliding-window size for the dev-login rate limiter.
AUTH_DEV_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Frontend
# Optional override. Leave empty to use "<current-host>:8000" (works on LAN/mobile).
VITE_API_URL=
# Optional build-time base path override for path-based hosting such as /ping-watch/.
VITE_BASE_PATH=
# Required only when frontend should mirror backend auth enforcement.
VITE_AUTH_REQUIRED=false
# Optional; set `true` to auto-bootstrap a dev auth session in the frontend.
VITE_AUTH_AUTO_LOGIN=false
# Optional comma-separated extra hosts allowed by Vite dev server (for tunnels).
VITE_ALLOWED_HOSTS=
# Optional; event polling interval in milliseconds.
VITE_POLL_INTERVAL_MS=
# Optional; pending-upload retry interval in milliseconds.
VITE_UPLOAD_INTERVAL_MS=
# Optional; set `true` to skip media capture in tests/E2E or unsupported browsers.
VITE_DISABLE_MEDIA=

# Inference providers
# Optional; required only when using NVIDIA-hosted inference.
NVIDIA_API_KEY=
# Optional; required only when using Hugging Face-hosted inference.
HF_TOKEN=
# Optional; number of frames sampled from each clip for inference.
INFERENCE_NUM_FRAMES=3
# Optional; outbound inference request timeout in seconds.
INFERENCE_TIMEOUT_SECONDS=120
# Optional; extra retries when NVIDIA inference times out.
NVIDIA_INFERENCE_TIMEOUT_RETRIES=1

# Outbound notifications
# Keep secrets only in untracked env files or your secret manager. Generate unique values per environment and rotate immediately after any exposure.
# Optional; required only when Telegram notifications/linking are enabled.
TELEGRAM_BOT_TOKEN=
# Bot URL used by onboarding (for example https://t.me/PingUser_bot).
# Optional; required only when Telegram notifications/linking are enabled.
TELEGRAM_BOT_ONBOARDING_URL=
# Optional override for Telegram API base URL (default https://api.telegram.org).
TELEGRAM_API_BASE_URL=
# Optional; one-time token lifetime for Telegram link attempts.
TELEGRAM_LINK_TOKEN_TTL_SECONDS=600
# Optional but strongly recommended when Telegram webhook is enabled; verifies inbound Telegram webhook calls.
TELEGRAM_WEBHOOK_SECRET=
# Optional; `true` sends the event clip to Telegram when available, `false` sends text-only alerts.
TELEGRAM_SEND_VIDEO=true
# Optional; set this to send alert payloads to another system in addition to Telegram.
NOTIFY_WEBHOOK_URL=
# Optional; shared secret header for the outbound webhook target above.
NOTIFY_WEBHOOK_SECRET=
# Optional; timeout in seconds for outbound notification requests.
NOTIFICATION_TIMEOUT_SECONDS=10
# Optional; worker log verbosity.
WORKER_LOG_LEVEL=INFO
# Required when `AUTH_REQUIRED=true` and the worker posts results back to the backend.
WORKER_API_TOKEN=
